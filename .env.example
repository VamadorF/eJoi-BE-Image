# Server
PORT=3000
LOG_LEVEL=info

# OpenAI
OPENAI_API_KEY=your_openai_key
LLM_MODEL=gpt-4o-mini
LLM_MAX_OUTPUT_TOKENS=300
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_MS=12000

# Proveedor de imágenes (openai | segmind | flux)
IMAGE_PROVIDER=openai
ENABLE_IMAGE_PROVIDER_FALLBACK=false

# Segmind (Imagen 4 Fast)
SEGMIND_API_KEY=
SEGMIND_DEFAULT_ASPECT_RATIO=16:9
SEGMIND_NEGATIVE_PROMPT=blurry, pixelated, ugly, distorted, low quality

# Replicate (FLUX.1 Schnell)
REPLICATE_API_KEY=
FLUX_DEFAULT_GUIDANCE_SCALE=3.5
FLUX_DEFAULT_NUM_INFERENCE_STEPS=4
FLUX_GO_FAST=true

# JWT
JWT_SECRET=your_secret
JWT_EXPIRES_IN=7d

# Google Cloud Storage
GCP_PROJECT_ID=your_project_id
GCP_CLIENT_EMAIL=your_client_email
GCP_PRIVATE_KEY=your_private_key
GCS_BUCKET_NAME=your_bucket_name

# Redis
REDIS_URL=redis://localhost:6379
